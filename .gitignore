# Qubes Air
# ===============================================

# -----------------------------------------------
# 数据库文件
# -----------------------------------------------
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# -----------------------------------------------
# 构建产物
# -----------------------------------------------
/console/frontend/dist/
/console/backend/bin/
/console/backend/server
/packer/output/
*.exe
*.exe~
*.dll
*.so
*.dylib

# -----------------------------------------------
# 配置文件 (保留 example)
# -----------------------------------------------
/console/backend/config.yaml
/console/frontend/.env
/console/frontend/.env.local
/console/frontend/.env.*.local

# -----------------------------------------------
# Go
# -----------------------------------------------
vendor/
go.work
go.work.sum
*.out
coverage.out
coverage.html
gosec-results.sarif

# -----------------------------------------------
# Node.js / Frontend
# -----------------------------------------------
/console/frontend/node_modules/
/console/frontend/.svelte-kit/
.npm
*.tsbuildinfo

# -----------------------------------------------
# Terraform / OpenTofu
# -----------------------------------------------
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl
*.tfvars
!*.tfvars.example
# 注: gitignore 不支持行尾注释, 且带斜杠的模式锚定仓库根 ——
# 原来的 `!environments/*.tfvars` 匹配的是 <root>/environments/, 而真实路径是
# terraform/environments/, 所以示例配置一直被静默忽略、从未进过 git。
!terraform/environments/*.tfvars
# 真实环境配置含集群地址与公钥, 仍然排除。
terraform/environments/infra.tfvars
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
# Remote backend / state encryption config: contains env-specific values
# (bucket/endpoint) and must never carry the passphrase — keep out of git.
# Commit only the *.example templates.
backend.tf
encryption.tf
# OpenTofu encrypted state fallback / plan files
*.tfplan

# -----------------------------------------------
# Packer
# -----------------------------------------------
packer_cache/

# -----------------------------------------------
# Ansible
# -----------------------------------------------
*.retry
ansible/*.log

# -----------------------------------------------
# 敏感文件 / Secrets
# -----------------------------------------------
*.key
*.pem
*.p12
*.pfx
secrets.sls
!secrets.sls.example
.sops.yaml
.age.key
*.age
!*.age.pub

# -----------------------------------------------
# 加密文件 (保留 .enc 后缀文件)
# -----------------------------------------------
# *.enc

# -----------------------------------------------
# 编辑器 / IDE
# -----------------------------------------------
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.bak
*.orig
\#*\#
.#*

# -----------------------------------------------
# OS 生成文件
# -----------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------
# 日志 / 调试
# -----------------------------------------------
*.log
/console/backend/log/
debug/
tmp/
temp/

# -----------------------------------------------
# 测试 / 覆盖率
# -----------------------------------------------
coverage/
.nyc_output/
htmlcov/
.coverage
.coverage.*
*.cover
*.py[cod]
__pycache__/

# -----------------------------------------------
# 安全扫描结果
# -----------------------------------------------
trivy-results.sarif
tfsec-results.sarif
gitleaks-report.json

# -----------------------------------------------
# 其他
# -----------------------------------------------
.env
.env.local
.env.*.local
*.local
.cache/

# Console 渲染的 terraform 变量文件 (由数据库生成, 不是手写配置)
terraform/generated/

# Go 编译产物 (cmd/<name> 构建到 backend 根目录时会裸露在工作区)
console/backend/grpc-server
console/backend/grpc-smoke
console/backend/relay-client
console/backend/rotate-key
console/backend/qubes-air-console

# Console 渲染的 agent 身份文件 (含私钥)
terraform/identities/

# scripts/build-agent-deb.sh 的输出 (.deb 是构建产物, 分发走 artifact store)
dist/
