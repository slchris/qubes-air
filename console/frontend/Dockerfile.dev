# Development image for the console frontend (vite dev server, HMR).
#
# The production bundle is built by .github/workflows/release.yml and shipped as
# qubes-air-console-web.tar.gz; this image is only for editing with hot reload.
FROM node:22-bookworm-slim

WORKDIR /app

# Dependencies as their own layer, so editing a component does not reinstall.
COPY package.json package-lock.json ./
RUN npm ci

# Source is bind-mounted by compose. node_modules is NOT: the compose file puts
# a named volume over /app/node_modules so the container keeps the linux
# binaries installed above rather than seeing the host's — which on an Apple
# Silicon machine are arm64 macOS builds that cannot run here, and which would
# otherwise be shadowed in exactly the way that produces an unrunnable esbuild.

EXPOSE 5173

# --host 0.0.0.0 so the port is reachable from outside the container; vite binds
# loopback by default, which inside a container means nothing can connect.
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
